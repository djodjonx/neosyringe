{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "group-pull-request-title-pattern": "chore: release",
  "packages": {
    "packages/neosyringe": {
      "package-name": "@djodjonx/neosyringe",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/core": {
      "package-name": "@djodjonx/neosyringe-core",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/lsp": {
      "package-name": "@djodjonx/neosyringe-lsp",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/cli": {
      "package-name": "@djodjonx/neosyringe-cli",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/unplugin": {
      "package-name": "@djodjonx/neosyringe-plugin",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "groups": {
    "neosyringe": {
      "packages": [
        "packages/neosyringe",
        "packages/core",
        "packages/lsp",
        "packages/cli",
        "packages/unplugin"
      ]
    }
  }
}
